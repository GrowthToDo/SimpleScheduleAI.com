---
import BaseLayout from "@layout/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import Button from "@ui/Button.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const seo = {
  title: `${article.data.title} - SimpleScheduleAI`,
  description: article.data.description,
};
---

<BaseLayout seo={seo}>
  {/* Dark hero */}
  <section class="relative overflow-hidden bg-slate-950 -mt-32 sm:-mt-36 lg:-mt-40">
    <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-teal-700/20 blur-3xl"></div>
    <div class="mx-auto max-w-[85rem] px-4 pt-44 pb-16 sm:px-6 sm:pt-48 lg:px-8 lg:pt-52">
      <div class="mb-5">
        <a href="/articles" class="inline-flex items-center text-sm font-semibold text-teal-400 hover:text-teal-300">
          &larr; Back to articles
        </a>
      </div>
      <time class="text-sm text-slate-500">
        {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <h1 class="mt-3 text-balance text-4xl font-black text-white sm:text-5xl lg:text-6xl">
        {article.data.title}
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-400">
        {article.data.description}
      </p>
    </div>
  </section>

  {/* Article content */}
  <article class="bg-white">
    <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto max-w-3xl">
        <div class="prose prose-slate prose-lg max-w-none">
          <Content />
        </div>

        <div class="mt-12 rounded-2xl border border-teal-200 bg-teal-50 p-8">
          <h2 class="text-xl font-semibold text-slate-900">Ready to transform your scheduling?</h2>
          <p class="mt-3 text-slate-700">
            Learn how SimpleScheduleAI helps Texas Critical Access Hospitals reduce scheduling chaos, overtime, and burnout.
          </p>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <Button href="/contact" variant="primary">
              Request a pilot
            </Button>
            <Button href="/how-it-works" variant="secondary">
              How it works
            </Button>
          </div>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
