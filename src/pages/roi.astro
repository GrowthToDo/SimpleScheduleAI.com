---
import BaseLayout from "@layout/BaseLayout.astro";
import ROISection from "@sections/ROISection.astro";
import Button from "@ui/Button.astro";

const seo = {
  title: "Scheduling Cost Calculator - SimpleScheduleAI",
  description: "Calculate what nurse scheduling is really costing your Critical Access Hospital in Texas. Adjust sliders to match your hospital's size and see your hidden scheduling costs.",
};
---

<BaseLayout seo={seo}>
  {/* Dark hero */}
  <section class="relative overflow-hidden bg-slate-950 -mt-32 sm:-mt-36 lg:-mt-40">
    <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-teal-700/20 blur-3xl"></div>
    <div class="mx-auto max-w-[85rem] px-4 pt-44 pb-16 sm:px-6 sm:pt-48 lg:px-8 lg:pt-52">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-teal-700/40 bg-teal-900/40 px-4 py-1.5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400"></span>
        <span class="text-xs font-semibold tracking-widest text-teal-300 uppercase">Scheduling Cost Calculator</span>
      </div>
      <h1 class="text-balance text-4xl font-black text-white sm:text-5xl lg:text-6xl">
        What is scheduling really costing you?
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-400">
        Adjust the sliders to match your hospital. Based on interviews with 30+ nurse managers and published CAH benchmarks.
      </p>
    </div>
  </section>

  {/* Calculator */}
  <ROISection />

  {/* CTA */}
  <section class="bg-white pb-20">
    <div class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8 text-center">
      <Button href="/contact" variant="primary" className="inline-flex px-6! py-3! text-base!">
        Apply for a Pilot Spot
      </Button>
      <p class="mt-3 text-sm text-slate-500">Free 60-day pilot. No obligation.</p>
    </div>
  </section>
</BaseLayout>
