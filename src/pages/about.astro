---
import BaseLayout from "@layout/BaseLayout.astro";
import Button from "@ui/Button.astro";
import type { WithContext, Thing } from "schema-dts";

const pageTitle = "About SimpleScheduleAI";
const pageDescription =
  "Assisted nurse scheduling for Critical Access Hospitals in Texas. We reduce scheduling load while your team keeps tools, control, and final approval.";

const seo = {
  title: pageTitle,
  description: pageDescription,
};

const schema: WithContext<Thing> = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  inLanguage: "en-US",
  "@id": Astro.url.href,
  url: Astro.url.href,
  name: pageTitle,
  description: pageDescription,
  isPartOf: {
    "@type": "WebSite",
    url: `${Astro.site}`,
    name: "SimpleScheduleAI",
    description: pageDescription,
  },
};

const stats = [
  { label: "Built for", value: "Critical Access Hospitals in Texas" },
  { label: "Works with", value: "Excel and your current format" },
  { label: "Designed for", value: "Nurse managers and leadership" },
  { label: "Approach", value: "Assisted, not replacement" },
];

const principles = [
  {
    title: "You keep control",
    description:
      "Your team owns the rules, the exceptions, and the final approval. We support the work, you decide what goes live.",
  },
  {
    title: "Fits your current workflow",
    description:
      "No new software rollout. No training burden. We work with the format you already use, including Excel.",
  },
  {
    title: "Clear handoffs",
    description:
      "You get a review ready schedule, notes on conflicts and assumptions, and a simple validation summary for quick sign off.",
  },
];

const whatWeDo = [
  "Build draft schedules based on your inputs and constraints",
  "Validate coverage, gaps, conflicts, and common failure points",
  "Return a clean, review ready version for your approval",
];

const whatWeDoNotDo = [
  "We do not publish schedules without your approval",
  "We do not change your policies or override your leadership",
  "We do not replace your staff or act as your HR system",
];

const ctaLink = "https://cal.com/gautham-8bdvdx/30min";
---

<BaseLayout seo={seo} schema={schema}>
  {/* Dark hero */}
  <section class="relative overflow-hidden bg-slate-950 -mt-32 sm:-mt-36 lg:-mt-40">
    <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[400px] w-[600px] rounded-full bg-teal-700/20 blur-3xl"></div>
    <div class="mx-auto max-w-[85rem] px-4 pt-44 pb-16 sm:px-6 sm:pt-48 lg:px-8 lg:pt-52">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-teal-700/40 bg-teal-900/40 px-4 py-1.5">
        <span class="h-1.5 w-1.5 rounded-full bg-teal-400"></span>
        <span class="text-xs font-semibold tracking-widest text-teal-300 uppercase">About Us</span>
      </div>
      <h1 class="text-balance text-4xl font-black text-white sm:text-5xl lg:text-6xl">
        Built for hospitals where<br />the schedule never stops
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-slate-400">
        {pageDescription}
      </p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <Button href="/how-it-works" variant="primary">See how it works</Button>
        <a
          href={ctaLink}
          class="rounded-lg px-6 py-2.5 text-center font-medium transition-colors duration-300 border-2 border-slate-600 text-slate-300 hover:border-teal-600 hover:text-white"
        >
          Book a call
        </a>
      </div>
    </div>
  </section>

  {/* Stats */}
  <section class="bg-white">
    <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <dl class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="rounded-2xl border border-slate-200 bg-slate-50 p-6">
              <dt class="text-xs font-semibold uppercase tracking-widest text-teal-600">{stat.label}</dt>
              <dd class="mt-3 text-lg font-semibold text-slate-900">{stat.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>

  {/* Principles */}
  <section class="bg-slate-50">
    <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-teal-600">How we operate</p>
        <h2 class="text-balance text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Our operating principles
        </h2>
        <p class="mt-4 text-lg text-slate-600">
          This is a workflow support service, not a software rollout.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-3">
        {
          principles.map((p) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-7 shadow-sm">
              <h3 class="text-lg font-semibold text-slate-900">{p.title}</h3>
              <p class="mt-3 text-slate-700">{p.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* What we do / do not do */}
  <section class="bg-white">
    <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-teal-600">Scope of service</p>
        <h2 class="text-balance text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
          Clear boundaries, by design
        </h2>
      </div>
      <div class="mx-auto max-w-6xl grid gap-6 lg:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-7">
          <h3 class="text-xl font-semibold text-slate-900">What we do</h3>
          <ul class="mt-4 space-y-3">
            {whatWeDo.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-teal-600"></span>
                <span class="text-slate-700">{item}</span>
              </li>
            ))}
          </ul>
          <p class="mt-5 text-sm text-slate-500">
            You review and approve. Nothing is final until your team signs off.
          </p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-7">
          <h3 class="text-xl font-semibold text-slate-900">What we do not do</h3>
          <ul class="mt-4 space-y-3">
            {whatWeDoNotDo.map((item) => (
              <li class="flex items-start gap-3">
                <span class="mt-1.5 size-1.5 shrink-0 rounded-full bg-slate-400"></span>
                <span class="text-slate-700">{item}</span>
              </li>
            ))}
          </ul>
          <p class="mt-5 text-sm text-slate-500">
            This clarity is intentional. It keeps expectations clean and risk low.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Dark CTA */}
  <section class="bg-slate-900">
    <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-teal-400">Low risk. No obligation.</p>
        <h2 class="text-balance text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Want to sanity check fit before anything else?
        </h2>
        <p class="mt-5 text-lg text-slate-400">
          If scheduling is draining time and attention, the pilot is a low risk way to test a better workflow.
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <Button href="/pilot" variant="primary">View the pilot</Button>
          <a
            href={ctaLink}
            class="rounded-lg px-6 py-2.5 text-center font-medium transition-colors duration-300 border-2 border-slate-600 text-slate-300 hover:border-teal-600 hover:text-white"
          >
            Book a call
          </a>
        </div>
        <p class="mt-6 text-sm text-slate-500">Simple process. Clear handoffs. Your final approval.</p>
      </div>
    </div>
  </section>
</BaseLayout>
