---
import Button from "@ui/Button.astro";

const title = "3 pilot spots open.<br/>No cost. No obligation.";

const bullets = [
  "A compliant, post-ready schedule delivered every week",
  "Call-out replacement candidates, ready to approve in one click",
  "A weekly manager summary: what changed, budget impact, pending approvals",
];

const postPilot =
  "After 60 days, we sit down for a strategic review. If it is working and you want to continue, we build a plan together. The pilot costs you nothing.";

const primaryCTA = {
  text: "Claim a Pilot Spot",
  href: "/contact",
};

const secondaryCTA = {
  text: "Get a walkthrough first",
  href: "/how-it-works",
};

const tags = ["Free for 60 Days", "3 Hospitals Only", "Full Managed Service", "No IT Setup"];
---

<section class="bg-slate-950">
  <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 md:py-24 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-teal-400">Limited availability</p>
      <h2 class="text-balance text-4xl font-black text-white sm:text-5xl">
        <Fragment set:html={title} />
      </h2>

      <p class="mt-6 text-sm font-semibold uppercase tracking-widest text-slate-500">What you get for 60 days, free</p>
      <ul class="mt-4 space-y-3 text-left">
        {bullets.map((bullet) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 shrink-0 text-teal-400">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
              </svg>
            </span>
            <span class="text-lg leading-relaxed text-slate-300">{bullet}</span>
          </li>
        ))}
      </ul>

      <p class="mt-6 text-pretty text-base leading-relaxed text-slate-500">
        {postPilot}
      </p>

      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <Button href={primaryCTA.href} variant="primary" className="inline-flex border-none px-6!">
          {primaryCTA.text}
        </Button>

        <a href={secondaryCTA.href} class="rounded-lg px-6 py-2.5 text-center font-medium transition-colors duration-300 border-2 border-slate-600 text-slate-300 hover:border-teal-600 hover:text-white">
          {secondaryCTA.text}
        </a>
      </div>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
        {tags.map((tag) => (
          <span class="inline-flex items-center gap-x-1.5 rounded-full border border-teal-800/50 bg-teal-900/30 px-3 py-1.5 text-xs font-medium text-teal-300">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
