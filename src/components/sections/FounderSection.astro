---
const founders = [
  {
    name: "Pradeep Pandey",
    title: "Co-founder",
    bio: "7 years inside hospital operations. Watched scheduling break good nurses and decided to fix it before it happened to your unit.",
    imageAlt: "Pradeep Pandey, Co-founder of SimpleScheduleAI",
    imageSrc: "/founders/pradeep.webp",
  },
  {
    name: "Gautham",
    title: "Co-founder",
    bio: "3x founder, 15 years in tech. Built the system so it works without your nurses or staff touching any software.",
    imageAlt: "Gautham, Co-founder of SimpleScheduleAI",
    imageSrc: "/founders/gautham.png",
  },
];
---

<section class="bg-white">
  <div class="mx-auto max-w-[85rem] px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-teal-600">The team</p>
      <h2 class="text-balance text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Built by people who've been in the room
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-slate-600">
        We interviewed 30+ nurse managers before writing a single line of code.
        Not surveys. Real conversations about real scheduling problems.
      </p>
    </div>

    <div class="mt-14 flex flex-col items-center justify-center gap-12 sm:flex-row sm:items-start sm:gap-20">
      {founders.map((founder) => (
        <div class="flex max-w-xs flex-col items-center text-center">
          <img
          src={founder.imageSrc}
          alt={founder.imageAlt}
          class="h-24 w-24 rounded-full object-cover ring-4 ring-teal-100"
          loading="lazy"
          decoding="async"
          />
          <h3 class="mt-5 text-lg font-bold text-slate-900">{founder.name}</h3>
          <p class="text-sm font-semibold text-teal-600">{founder.title}</p>
          <p class="mt-3 text-sm leading-relaxed text-slate-600">{founder.bio}</p>
        </div>
      ))}
    </div>
  </div>
</section>
